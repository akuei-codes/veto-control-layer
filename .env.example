# ── Veto — environment variables ────────────────────────────────────────────
# Copy this file to `.env` and fill in real values.
# When these variables are missing the app runs in **DEMO MODE** with an
# in-memory store; no remote auth or persistence is used.

# ── Lovable Cloud (Supabase under the hood) ────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── App URLs ──────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
VITE_AUTH_REDIRECT_URL=http://localhost:5173/auth/callback

# ── OAuth — Google ────────────────────────────────────────────────────────
# Configure these in the Supabase dashboard → Authentication → Providers.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub ────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
